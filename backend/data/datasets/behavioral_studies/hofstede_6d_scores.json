{
  "_description": "Hofstede 6-Dimension Cultural Scores — calibrated reference dataset for cultural modifier tuning.",
  "_source": {
    "primary": "Hofstede, G. (2010). Cultures and Organizations: Software of the Mind, 3rd ed.",
    "derived_from": "https://clearlycultural.com/geert-hofstede-cultural-dimensions/ (public scores fetched 2026-04-18)",
    "official_matrix": "https://geerthofstede.com/research-and-vsm/dimension-data-matrix/",
    "methodology_reference": "Hofstede, G., Hofstede, G. J., & Minkov, M. (2010)"
  },
  "_dimensions": {
    "PDI": "Power Distance Index (0-100+). Higher = greater acceptance of hierarchical distribution of power.",
    "IDV": "Individualism (0-100). Higher = more individualist; lower = more collectivist.",
    "MAS": "Masculinity (0-100). Higher = more competitive/achievement-oriented; lower = more cooperative/quality-of-life.",
    "UAI": "Uncertainty Avoidance Index (0-100+). Higher = less tolerance for ambiguity, more rules sought.",
    "LTO": "Long-term Orientation (0-100). Higher = future-focused, pragmatic. Not populated for all countries.",
    "IVR": "Indulgence vs Restraint (0-100). Higher = more indulgent. Not populated for all countries."
  },
  "_hospitality_dimension_relevance": {
    "PDI": "High PDI guests expect service hierarchy and deference; low PDI expect egalitarian interactions",
    "IDV": "High IDV guests expect personalized recognition; low IDV accept group treatment",
    "MAS": "High MAS guests value performance/excellence signaling; low MAS value comfort and cooperation",
    "UAI": "High UAI guests want rules, clarity, visible SOPs, cleanliness certifications; low UAI tolerate chaos"
  },

