  "nps_calculation": {
    "_calibration_note": "NPS thresholds anchored to Meliá / Gran Meliá disclosed benchmarks (2023-2024 annual reports): industry luxury NPS 60-75, mass-market 35-45. Current mapping targets avg final_score 70 → NPS +45 for a typical 4★ stay.",
    "formula": "weighted_avg_final_sensations * archetype_importance - penalty_negative_moments + bonus_positive_moments",
    "thresholds": {
      "promoter_above": 72,
      "passive_range": [52, 72],
      "detractor_below": 52
    }
  },

  "star_rating_bucket": {
    "_calibration_note": "Thresholds recalibrated 2026-04-18 against Booking.com 2024 empirical distribution for 5-star Mediterranean hotels. Previous 82 threshold for 5★ was too strict: real Booking 9.2-9.5 scores map to sensation score ~78-85. Downshifted bucket anchors by ~4 points to match observed distribution (62/24/8/3/3 for typical luxury property).",
    "5_star_above_score": 78,
    "4_star_range": [62, 78],
    "3_star_range": [45, 62],
    "2_star_range": [28, 45],
    "1_star_below": 28
  }
}
